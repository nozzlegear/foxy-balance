/// Podman quadlet configuration for FoxyBalance — generates native systemd unit files.
module pod

/// Full image reference for the app container, including tag and digest.
/// Injected at deploy time: pkl eval ... -p "appImageName=ghcr.io/nozzlegear/foxy-balance:N@sha256:..."
appImageName: String = read("prop:appImageName")

local postgresImage: String = "docker.io/library/postgres:18-alpine@sha256:154ea39af68ff30dec041cd1f1b5600009993724c811dbadde54126eb10bedd1"

output {
  files {
    ["foxy-balance-app.container"] {
      text = """
        [Unit]
        Description=FoxyBalance Application
        After=local-fs.target network-online.target foxy-balance.network.service foxy-balance-db.service
        Wants=foxy-balance.network.service
        Requires=foxy-balance-db.service

        [Container]
        Image=\(appImageName)
        ContainerName=foxy-balance-app
        Network=foxy-balance.network
        PublishPort=7010:3000
        Environment=ASPNETCORE_ENVIRONMENT=Production
        Secret=foxybalance_secrets,type=mount,target=/run/secrets/appsettings.secrets.json
        LogDriver=journald

        # Health check
        HealthCmd=["wget", "--spider", "http://0.0.0.0:3000/health"]
        HealthInterval=10s
        HealthTimeout=5s
        HealthRetries=10
        HealthStartPeriod=30s

        [Service]
        Restart=always
        TimeoutStartSec=300

        [Install]
        WantedBy=multi-user.target default.target
        """
    }
    ["foxy-balance-db.container"] {
      text = """
        [Unit]
        Description=FoxyBalance PostgreSQL Database
        After=local-fs.target network-online.target foxy-balance.network.service
        Wants=foxy-balance.network.service

        [Container]
        Image=\(postgresImage)
        ContainerName=foxy-balance-db
        Network=foxy-balance.network
        PublishPort=7011:5432
        Environment=POSTGRES_DB=foxybalance
        Environment=PGDATA=/var/lib/postgresql/18/docker
        Secret=foxybalance_pg_username,type=env,target=POSTGRES_USER
        Secret=foxybalance_pg_password,type=env,target=POSTGRES_PASSWORD
        Volume=foxybalance-pvc:/var/lib/postgresql
        LogDriver=journald

        # Health check
        HealthCmd=/bin/sh -c 'pg_isready -U $POSTGRES_USER -d $POSTGRES_DB'
        HealthInterval=30s
        HealthTimeout=10s
        HealthRetries=3
        HealthStartPeriod=60s

        [Service]
        Restart=always

        [Install]
        WantedBy=multi-user.target default.target
        """
    }
    ["foxy-balance.network"] {
      text = """
        [Unit]
        Description=Network for FoxyBalance containers

        [Network]

        [Install]
        WantedBy=default.target
        """
    }
    ["foxy-balance.volume"] {
      text = """
        [Unit]
        Description=Persistent volume for FoxyBalance PostgreSQL data

        [Volume]
        VolumeName=foxybalance-pvc

        [Install]
        WantedBy=default.target
        """
    }
  }
}
